# =========================================================
# market-relay-engine-v2 .gitignore
# Python + trading data pipeline + QuestDB + local secrets
# =========================================================


# ---------------------------------------------------------
# Secrets / environment files
# ---------------------------------------------------------
.env
*.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Keep the safe template
!.env.example


# ---------------------------------------------------------
# Python bytecode / cache
# ---------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd


# ---------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/


# ---------------------------------------------------------
# Python build / packaging
# ---------------------------------------------------------
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST


# ---------------------------------------------------------
# C extensions / compiled files
# ---------------------------------------------------------
*.so
*.dll
*.dylib


# ---------------------------------------------------------
# Installer logs
# ---------------------------------------------------------
pip-log.txt
pip-delete-this-directory.txt


# ---------------------------------------------------------
# Test / coverage / lint cache
# ---------------------------------------------------------
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache/
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/
.ruff_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/


# ---------------------------------------------------------
# Jupyter / notebooks
# ---------------------------------------------------------
.ipynb_checkpoints/


# ---------------------------------------------------------
# IDE / editor files
# ---------------------------------------------------------
.vscode/
.idea/
.spyderproject
.spyproject
.ropeproject
tempCodeRunnerFile.py


# ---------------------------------------------------------
# OS files
# ---------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini


# ---------------------------------------------------------
# Local logs
# Keep folder placeholders but ignore real logs
# ---------------------------------------------------------
logs/*
!logs/.gitkeep
*.log


# ---------------------------------------------------------
# Project data folders
# Keep folder placeholders but ignore generated/raw data
# ---------------------------------------------------------
data/*
!data/.gitkeep
!data/raw/
!data/parquet/
!data/reports/
!data/logs/
!data/emergency_ledger/
!data/spool/
!data/dead_letter/

data/raw/*
!data/raw/.gitkeep

data/parquet/*
!data/parquet/.gitkeep

data/reports/*
!data/reports/.gitkeep

data/logs/*
!data/logs/.gitkeep

data/emergency_ledger/*
!data/emergency_ledger/.gitkeep
data/emergency_ledger/*.jsonl

data/spool/*
!data/spool/.gitkeep

data/dead_letter/*
!data/dead_letter/.gitkeep

data_lake/*
!data_lake/.gitkeep
!data_lake/raw/
!data_lake/features/
!data_lake/system/

data_lake/raw/*
!data_lake/raw/.gitkeep

data_lake/features/*
!data_lake/features/.gitkeep

data_lake/system/*
!data_lake/system/.gitkeep


# ---------------------------------------------------------
# Market data / Databento / archive formats
# Do NOT globally ignore *.csv because tests may use tiny CSV fixtures.
# Put real raw CSV data under data/ or data_lake/ so it is ignored there.
# ---------------------------------------------------------
*.parquet
*.dbn
*.dbn.zst
*.feather
*.arrow


# ---------------------------------------------------------
# Generated archives / manifests
# ---------------------------------------------------------
archives/*
!archives/.gitkeep

manifests/*
!manifests/.gitkeep

*.sha256
archive_manifest*.json


# ---------------------------------------------------------
# Local databases
# ---------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*.sqlite-journal
*.sqlite3-journal


# ---------------------------------------------------------
# QuestDB local installs / data
# Do not commit QuestDB binaries or database folders.
# ---------------------------------------------------------
questdb/
questdb-data/
qdbroot/
questdb-*/
data/db/
data/log/
data/conf/


# ---------------------------------------------------------
# Local temp / backup files
# ---------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.backup
*.old
~$*
*.swp
*.swo


# ---------------------------------------------------------
# PyInstaller
# ---------------------------------------------------------
*.manifest
*.spec


# ---------------------------------------------------------
# Documentation builds
# ---------------------------------------------------------
docs/_build/
site/
.site/


# ---------------------------------------------------------
# PDM / UV / Poetry / Pixi
# ---------------------------------------------------------
.pdm-python
.pdm-build/
__pypackages__/
.pixi/

# Optional lockfiles:
# Keep lockfiles if you intentionally use one package manager.
# Uncomment only if needed.
# uv.lock
# poetry.lock
# pdm.lock
# Pipfile.lock


# ---------------------------------------------------------
# Misc framework caches
# ---------------------------------------------------------
.scrapy/
.webassets-cache
instance/
.streamlit/secrets.toml
.abstra/
marimo/_static/
marimo/_lsp/
__marimo__/


# ---------------------------------------------------------
# Broker / API export safety
# ---------------------------------------------------------
alpaca_orders*.json
alpaca_fills*.json
databento_downloads/
eia_raw/
fred_raw/
edgar_raw/
usaspending_raw/
yfinance_raw/
